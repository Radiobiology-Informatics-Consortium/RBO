        <obo:IAO_0000115>A material accumulation process during which solid particles are pulled through a water body by gravitation or centrifugal force and which ends when they settle on a solid surface.</obo:IAO_0000115>
        <obo:IAO_0000117 rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
