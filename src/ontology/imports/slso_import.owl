                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_00001995"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01001069"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A planet that is composed primarily of silicate rocks or metals.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>rocky planet</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>telluric planet</oboInOwl:hasExactSynonym>
        <oboInOwl:hasRelatedSynonym>Earth-like planet</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset>envoAstro</oboInOwl:inSubset>
        <rdfs:label xml:lang="en">terrestrial planet</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000958"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A planet that is composed primarily of silicate rocks or metals.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Terrestrial_planet</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000982 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01000982">
        <owl:equivalentClass>
