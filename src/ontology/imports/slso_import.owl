                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000689"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002124"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A material entity which 1) is spatially continuous, 2) is composed of material of comparable thickness, composition, and physical properties, and 3) is physically distinct from adjacent portions of environmental material.</obo:IAO_0000115>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <oboInOwl:creation_date>2013-10-15T16:42:02Z</oboInOwl:creation_date>
