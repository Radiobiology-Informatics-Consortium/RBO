            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A planetary crust is the outermost solid shell of a rocky planet or natural satellite, which is chemically distinct from the underlying mantle.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>crust</oboInOwl:hasBroadSynonym>
        <rdfs:comment>This class is meant to be applicable accross planets. Earth&apos;s crust would be an instance.</rdfs:comment>
        <rdfs:label xml:lang="en">planetary crust</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000638"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A planetary crust is the outermost solid shell of a rocky planet or natural satellite, which is chemically distinct from the underlying mantle.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Crust_(geology)</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000639 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01000639">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000281"/>
