        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UO_0000127"/>
        <rdfs:comment>&quot;A unit which is a standard measure of the quantity that expresses the ability of radiation to ionize air and thereby create electric charges which can be collected and measured.&quot; [ORCBS:ORCBS]</rdfs:comment>
        <rdfs:label>exposure unit</rdfs:label>
    </owl:Class>
    


