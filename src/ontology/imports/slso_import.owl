        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A material entity that has been processed by humans or their technology in any way, including intermediate products as well as final products.</owl:annotatedTarget>
        <rdfs:comment>https://en.wikipedia.org/wiki/Manufactured_product</rdfs:comment>
    </owl:Axiom>
    


