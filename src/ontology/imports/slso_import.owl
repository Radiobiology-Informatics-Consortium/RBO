    <!-- http://purl.obolibrary.org/obo/OBI_0002316 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002316">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002314"/>
