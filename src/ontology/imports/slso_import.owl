    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000638 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01000638">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000639"/>
