                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000800"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A planetary structural layer is laminar part of a terrestrial planet or other rocky body large enough to have differentiation by density. Planetary layers have differing physicochemical properties and composition.</obo:IAO_0000115>
        <obo:IAO_0000116>Label should be improved to match definition.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">planetary structural layer</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000640 -->

