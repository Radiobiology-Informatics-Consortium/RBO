        <obo:IAO_0000115>An process in which environmental parameters and variables are continually assayed.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>monitoring</oboInOwl:hasBroadSynonym>
        <rdfs:label>environmental monitoring</rdfs:label>
    </owl:Class>
    


