        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An amide of a carboxylic acid, having the structure RC(=O)NR2. The term is used as a suffix in systematic name formation to denote the -C(=O)NH2 group including its carbon atom.</obo:IAO_0000115>
        <chebi:charge>0</chebi:charge>
        <chebi:formula>CNOR3</chebi:formula>
        <chebi:mass>42.01680</chebi:mass>
        <chebi:monoisotopicmass>41.99799</chebi:monoisotopicmass>
        <chebi:smiles>[*]C(=O)N([*])[*]</chebi:smiles>
