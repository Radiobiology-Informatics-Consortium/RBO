        <obo:IAO_0000111>dose</obo:IAO_0000111>
        <obo:IAO_0000112>An organism has been injected 1ml of vaccine</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000123"/>
        <obo:IAO_0000115 xml:lang="en">A measurement datum that measures the quantity of something that may be administered to an organism or that an organism may be exposed to. Quantities of nutrients, drugs, vaccines and toxins are referred to as doses.</obo:IAO_0000115>
        <rdfs:label>dose</rdfs:label>
