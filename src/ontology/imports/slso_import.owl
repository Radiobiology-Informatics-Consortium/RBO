    <!-- http://purl.obolibrary.org/obo/OBI_0002231 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002231">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002224"/>
        <obo:IAO_0000111>pT4b (colon)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>A pathologic primary tumor stage for colon and rectum according to AJCC 7th edition indicating that the tumor directly invades other organs or structures.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>https://staging.seer.cancer.gov/tnm/input/1.0/colon/path_t/</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>pT4b (colon)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002233 -->

