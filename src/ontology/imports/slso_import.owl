        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An environmental material which is unable to resist shear forces and continuously deforms when subject to them.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Fluid"/>
        <oboInOwl:hasDbXref>https://github.com/EnvironmentOntology/envo/issues/940</oboInOwl:hasDbXref>
