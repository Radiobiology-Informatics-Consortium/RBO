                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ENVO_00002006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Hydrological condensation is a process in which atmospheric water vapour undergoes a phase transition from the gas phase to the liquid phase.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>condensation</oboInOwl:hasBroadSynonym>
        <oboInOwl:inSubset>envoAtmo</oboInOwl:inSubset>
        <oboInOwl:inSubset>envoPolar</oboInOwl:inSubset>
        <rdfs:comment>&quot;process&quot; is included in the label to make it clear that we are not referring to the condensed material (e.g. water droplets, window fog)</rdfs:comment>
        <rdfs:label xml:lang="en">hydrological condensation process</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000624"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
