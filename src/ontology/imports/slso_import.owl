                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000076"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Outermost layer of cells surrounding the embryo.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>EVL</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>enveloping layer</oboInOwl:hasExactSynonym>
        <rdfs:label>enveloping layer of ectoderm</rdfs:label>
    </owl:Class>
    


