    <!-- http://purl.obolibrary.org/obo/OBI_0000571 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000571">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OMRSE_00000048"/>
