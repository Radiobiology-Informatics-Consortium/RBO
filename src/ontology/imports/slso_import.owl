                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_50860"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Chemically-enriched sediment which has increased levels of organic compounds.</obo:IAO_0000115>
        <rdfs:label>organically enriched sediment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_00002203 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_00002203">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_00002114"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/ENVO_02000200"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_24835"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
