    <!-- http://purl.obolibrary.org/obo/ENVO_00001995 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_00001995">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000814"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000386"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000256"/>
        <obo:IAO_0000115>A rock is a naturally occurring solid aggregate of one or more minerals or mineraloids.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>EcoLexicon:rock</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FTT:1010</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FTT:145</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Geonames:T.RK</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Geonames:T.RKS</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SWEETRealm:Rock</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TGN:21444</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Rock</oboInOwl:hasDbXref>
        <rdfs:comment>From https://en.wikipedia.org/wiki/ [A mineral] is different from a rock, which can be an aggregate of minerals or non-minerals and does not have a specific chemical composition. The exact definition of a mineral is under debate, especially with respect to the requirement a valid species be abiogenic, and to a lesser extent with regards to it having an ordered atomic structure.</rdfs:comment>
        <rdfs:label>rock</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_00001995"/>
