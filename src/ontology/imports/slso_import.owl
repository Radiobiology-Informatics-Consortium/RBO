                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ENVO_00000070"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An process during which natural or manufactured materials and products are processed and arranged by humans or their technology into structures.</obo:IAO_0000115>
        <obo:IAO_0000116>The nature of &quot;structures&quot; must be further specified.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">human-directed construction process</rdfs:label>
    </owl:Class>
    


