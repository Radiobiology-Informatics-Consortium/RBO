        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000150"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
