        <obo:IAO_0000115>An environmental system which includes both living and non-living components.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>LTER:173</oboInOwl:hasDbXref>
        <rdfs:comment>This class will be primarily filled by inference, any environmental system which necessarily includes living parts should be autoclassified here.</rdfs:comment>
        <rdfs:label xml:lang="en">ecosystem</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001110"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>An environmental system which includes both living and non-living components.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Ecosystem</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
