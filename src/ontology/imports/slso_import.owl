        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uo.owl"/>
        <rdfs:comment>&quot;A unit which represents a standard measurement of how much of a given substance there is mixed with another substance.&quot; [UOC:GVG]</rdfs:comment>
        <rdfs:label>concentration unit</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UO_0000055 -->

