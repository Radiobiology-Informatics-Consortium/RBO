            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Presumptive structure of the blastula that will develop into ectoderm.</obo:IAO_0000115>
        <oboInOwl:hasRelatedSynonym>presumptive epidermis</oboInOwl:hasRelatedSynonym>
        <rdfs:label>presumptive ectoderm</rdfs:label>
    </owl:Class>
    


