        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_03000033"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Sediment which has been transported through the marine water column, settling on the seafloor.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Pelagic_sediment#_note-8</oboInOwl:hasDbXref>
    </owl:Axiom>
    


