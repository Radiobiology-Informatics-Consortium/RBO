                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000993"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A material entity that has been processed by humans or their technology in any way, including intermediate products as well as final products.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>manufactured good</oboInOwl:hasExactSynonym>
        <rdfs:label>manufactured product</rdfs:label>
