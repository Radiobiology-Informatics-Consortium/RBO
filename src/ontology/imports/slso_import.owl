        <obo:IAO_0000115>Land which is below the freezing point of water.</obo:IAO_0000115>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-01-14T21:18:19Z</oboInOwl:creation_date>
