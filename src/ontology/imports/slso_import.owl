        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115>A histologic grade for ovarian tumor according to a two-tier grading system indicating that the tumor is low grade.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Low grade</obo:IAO_0000118>
