        <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000239"/>
        <rdfs:label xml:lang="en">Milligram Measurement Unit</rdfs:label>
        <skos:altLabel xml:lang="en">mg</skos:altLabel>
