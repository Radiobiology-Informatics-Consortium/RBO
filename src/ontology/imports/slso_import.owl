                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A planned process that intends to output material entities from input material entities</obo:IAO_0000115>
        <rdfs:label xml:lang="en">material processing</rdfs:label>
    </owl:Class>
    


