                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000924"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An anatomical structure that develops (entirely or partially) from the ectoderm.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>ectodermal deriviative</oboInOwl:hasExactSynonym>
        <rdfs:label>ectoderm-derived structure</rdfs:label>
    </owl:Class>
    


