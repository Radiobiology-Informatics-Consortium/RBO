    <!-- http://purl.obolibrary.org/obo/OBI_0002327 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002327">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002326"/>
