    </owl:NamedIndividual>
    


    <!-- https://www.commoncoreontologies.org/ont00001550 -->

    <owl:NamedIndividual rdf:about="https://www.commoncoreontologies.org/ont00001550">
        <rdf:type rdf:resource="https://www.commoncoreontologies.org/ont00000276"/>
        <rdfs:comment xml:lang="en">The Julian Calendar was proposed by Julius Caesar as a reform of the Roman Calendar, took effect on 1 January 46 BC, and was the predominant Calendar System in Europe until being largely replaced by the Gregorian Calendar.</rdfs:comment>
        <rdfs:label xml:lang="en">Julian Calendar</rdfs:label>
        <skos:definition xml:lang="en">A Solar Calendar System that has a regular Year of 365 24-Hour Days divided into 12 Months with a leap day added at the end of February every 4 Years such that the average length of a Julian Year is 365.25 Days.</skos:definition>
        <www:ont00001754 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/w/index.php?title=Julian_calendar&amp;oldid=1063127575</www:ont00001754>
        <www:ont00001760 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.commoncoreontologies.org/InformationEntityOntology</www:ont00001760>
    </owl:NamedIndividual>
    


    <!-- https://www.commoncoreontologies.org/ont00001551 -->

