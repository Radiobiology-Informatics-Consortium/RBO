    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0006598">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002050"/>
        <obo:IAO_0000115>Portion of embryonic tissue determined by fate mapping to become a structure.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>future structure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>presumptive structures</oboInOwl:hasExactSynonym>
        <rdfs:label>presumptive structure</rdfs:label>
    </owl:Class>
    


