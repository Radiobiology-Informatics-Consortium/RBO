        <rdfs:label>sloped downward</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0002181 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0002181">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0000140"/>
        <obo:IAO_0000115>A positional quality inhering in a bearer by virtue the bearer&apos;s being changed in position.</obo:IAO_0000115>
        <rdfs:label>displaced</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0002198 -->

