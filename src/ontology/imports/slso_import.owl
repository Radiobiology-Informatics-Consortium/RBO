            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An environmental system which is determined by materials bearing roughly homogeneous qualities.</obo:IAO_0000115>
        <rdfs:comment>Organisational class. Not intended for annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">environmental system determined by a quality</rdfs:label>
    </owl:Class>
    


