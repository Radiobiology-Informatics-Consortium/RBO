            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An environmental material which is unable to resist shear forces and continuously deforms when subject to them.</obo:IAO_0000115>
        <oboInOwl:hasNarrowSynonym>fluid</oboInOwl:hasNarrowSynonym>
        <rdfs:label xml:lang="en">fluid environmental material</rdfs:label>
    </owl:Class>
