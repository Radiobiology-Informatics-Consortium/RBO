            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A portion of tissue that is part of an embryo.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>portion of embryonic tissue</oboInOwl:hasExactSynonym>
        <oboInOwl:hasRelatedSynonym>developing tissue</oboInOwl:hasRelatedSynonym>
        <rdfs:label>embryonic tissue</rdfs:label>
    </owl:Class>
    


