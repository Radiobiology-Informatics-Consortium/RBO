        <obo:IAO_0000115>A material transformation process during which a material&apos;s viscosity increase either through a reduction in temperature, through chemical reactions, or other physical effects.</obo:IAO_0000115>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-01-14T18:47:32Z</oboInOwl:creation_date>
