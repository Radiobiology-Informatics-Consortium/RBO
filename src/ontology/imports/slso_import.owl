            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Ice which is primarily composed of carbon dioxide.</obo:IAO_0000115>
        <oboInOwl:hasRelatedSynonym>dry ice</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset>envoAstro</oboInOwl:inSubset>
