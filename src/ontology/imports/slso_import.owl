            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A data item that is more specifically a rectangular array of numbers, symbols, or expressions, arranged in rows and columns.</obo:IAO_0000115>
        <obo:IAO_0000117>Person: Oliver He, Jie Zheng</obo:IAO_0000117>
